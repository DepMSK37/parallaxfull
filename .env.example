# ══════════════════════════════════════════════════
# Parallax — конфигурация окружения
# Скопируйте этот файл в .env и заполните значения
# ══════════════════════════════════════════════════

# Токен основного бота (получить у @BotFather)
PARALLAX_BOT_TOKEN=123456:ABC-DEF-your-token-here

# Gemini API ключ (для модуля "Сканер смет")
GEMINI_API_KEY=your-gemini-api-key-here

# Пути к БД (опционально, есть дефолты)
# DELIVERY_DB_PATH=./data/deliveries.db
# ACCOUNTING_DB_PATH=./data/accounting.db

# Timezone для cron-задач (в модулях delivery и accounting)
# TZ=Europe/Moscow
